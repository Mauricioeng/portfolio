<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Maurício Matheus | Portfolio</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

  <style>
    :root {
      --primary-color: #026fb8;
      --secondary-color: #00a8cc;
      --accent-color: #005f73;
      --bg-color: #f4f6f9;
      --text-color: #334155;
      --heading-color: #0f172a;
      --card-bg-color: rgba(255, 255, 255, 0.85);
      --card-border: 1px solid rgba(2, 111, 184, 0.2);
      --box-shadow: 0px 8px 30px rgba(0, 0, 0, 0.04);
      --glass-shadow: 0 4px 20px rgba(2, 111, 184, 0.08);
      --transition: all 0.25s ease-out;

      /* Vanta & Equações Light Mode */
      --vanta-light-color: #026fb8;
      --vanta-light-bg: #f4f6f9;
      --equation-light-color: rgba(2, 111, 184, 0.1);
      --equation-light-shadow: rgba(2, 111, 184, 0.05);
    }

    body.dark-mode {
      --primary-color: #00ff41;
      /* Matrix Green */
      --secondary-color: #00f0ff;
      /* Cyan */
      --accent-color: #00ff41;
      --bg-color: #050505;
      --text-color: #94a3b8;
      --heading-color: #f8fafc;
      --card-bg-color: rgba(10, 15, 20, 0.75);
      --card-border: 1px solid rgba(0, 255, 65, 0.3);
      --box-shadow: 0px 8px 30px rgba(0, 0, 0, 0.6);
      --glass-shadow: 0 4px 20px rgba(0, 255, 65, 0.15);

      /* Vanta & Equações Dark Mode */
      --vanta-dark-color: #00ff41;
      --vanta-dark-bg: #050505;
      --equation-dark-color: rgba(0, 255, 65, 0.15);
      --equation-dark-shadow: rgba(0, 255, 65, 0.3);
    }

    html {
      scroll-behavior: smooth;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Roboto Mono', 'Inter', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-color);
      transition: background-color 0.4s ease, color 0.4s ease;
      overflow-x: hidden;
      line-height: 1.7;
      cursor: default;
      perspective: 1000px;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-family: 'Inter', sans-serif;
      font-weight: 700;
      letter-spacing: -0.03em;
    }

    /* Scroll Progress Bar */
    #scroll-progress {
      position: fixed;
      top: 0;
      left: 0;
      height: 4px;
      background: var(--primary-color);
      z-index: 9999;
      width: 0%;
      transition: width 0.1s;
      box-shadow: 0 0 10px var(--primary-color);
    }

    /* --- CURSOR CANVAS --- */
    #cursor-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 9998;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    ul {
      list-style: none;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
      position: relative;
    }

    /* --- HEADER --- */
    header {
      position: fixed;
      width: 100%;
      top: 0;
      left: 0;
      background-color: rgba(250, 250, 250, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: var(--glass-shadow);
      z-index: 1000;
      transition: var(--transition);
      border-bottom: var(--card-border);
    }

    body.dark-mode header {
      background-color: rgba(11, 13, 16, 0.7);
    }

    .header-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 0;
    }

    .logo {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--heading-color);
      text-shadow: 2px 2px 0px rgba(0, 0, 0, 0.1);
    }

    .logo span {
      color: var(--primary-color);
    }

    /* Desktop Nav */
    nav ul {
      display: flex;
      gap: 2rem;
    }

    nav ul li a {
      font-weight: 500;
      transition: var(--transition);
      color: var(--text-color);
      position: relative;
      font-size: 0.95rem;
    }

    nav ul li a:hover {
      color: var(--primary-color);
      transform: translateY(-2px);
      display: inline-block;
    }

    nav ul li a::after {
      content: '';
      position: absolute;
      width: 0;
      height: 2px;
      bottom: -5px;
      left: 0;
      background-color: var(--primary-color);
      transition: width 0.3s;
    }

    nav ul li a:hover::after {
      width: 100%;
    }

    /* Lang Selector Base Styles */
    .lang-selector {
      display: flex;
      gap: 0.3rem;
      font-size: 0.85rem;
    }

    .lang-selector button {
      background: none;
      border: 1px solid transparent;
      border-radius: 4px;
      cursor: pointer;
      padding: 0.2rem 0.4rem;
      transition: var(--transition);
      color: var(--text-color);
    }

    .lang-selector button:hover,
    .lang-selector button.active {
      border-color: var(--primary-color);
      color: var(--primary-color);
      font-weight: 600;
      box-shadow: 0 0 10px rgba(100, 244, 172, 0.2);
    }

    /* Mobile Language Selector (Hidden on Desktop) */
    .mobile-only-lang {
      display: none;
    }

    .utility-controls {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .theme-toggle,
    .sound-toggle {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1.2rem;
      color: var(--heading-color);
      transition: var(--transition);
    }

    .theme-toggle:hover {
      color: var(--primary-color);
      transform: rotate(20deg) scale(1.1);
    }

    .sound-toggle {
      width: 30px;
      text-align: center;
      margin-left: 0.5rem;
    }

    .sound-toggle:hover {
      color: var(--primary-color);
      text-shadow: 0 0 8px var(--primary-color);
      transform: scale(1.1);
    }

    .sound-toggle.muted {
      opacity: 0.5;
      color: var(--text-color);
    }

    .mobile-nav-toggle {
      display: none;
      cursor: pointer;
      font-size: 1.5rem;
      color: var(--heading-color);
      z-index: 1002;
      transition: transform 0.3s ease;
    }

    .mobile-nav-toggle.active {
      color: var(--primary-color);
    }

    section {
      padding: 8rem 0;
      position: relative;
    }

    .section-title {
      font-size: 2.8rem;
      font-weight: 800;
      text-align: center;
      margin-bottom: 4rem;
      color: var(--heading-color);
      position: relative;
      letter-spacing: -2px;
      transform-style: preserve-3d;
    }

    .section-title::after {
      content: '';
      position: absolute;
      bottom: -15px;
      left: 50%;
      transform: translateX(-50%);
      width: 60px;
      height: 4px;
      background-color: var(--primary-color);
      border-radius: 2px;
      box-shadow: 0 0 10px var(--primary-color);
    }

    /* --- HERO SECTION --- */
    .hero {
      position: relative;
      overflow: hidden;
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding-top: 6rem;
      background: var(--bg-color);
    }

    .hero>.vanta-canvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
    }

    .hero-content {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      perspective: 1000px;
    }

    .hero-image {
      position: relative;
      transition: opacity 0.5s ease-in-out;
      display: flex;
      justify-content: center;
      transform-style: preserve-3d;
    }

    body.dark-mode .hero-image {
      opacity: 0.9;
      filter: grayscale(20%);
      pointer-events: none;
    }

    /* Magnetic Equations */
    .equation-overlay {
      position: absolute;
      font-family: 'Roboto Mono', monospace;
      font-size: 1.2rem;
      color: var(--equation-light-color);
      text-shadow: 0 0 5px var(--equation-light-shadow);
      opacity: 0.6;
      cursor: crosshair;
      transition: color 0.3s ease, text-shadow 0.3s ease;
      animation: floatEquation 10s ease-in-out infinite;
      user-select: none;
    }

    body.dark-mode .equation-overlay {
      color: var(--equation-dark-color);
      text-shadow: 0 0 8px var(--equation-dark-shadow);
    }

    .equation-overlay.magnetic-active {
      transition: transform 0.1s ease-out !important;
    }

    .equation-overlay.eq1 {
      top: 15%;
      left: 10%;
      font-size: 1.5rem;
      animation-delay: 0s;
    }

    .equation-overlay.eq2 {
      bottom: 20%;
      right: 15%;
      font-size: 1.3rem;
      animation-delay: 2s;
    }

    .equation-overlay.eq3 {
      top: 40%;
      right: 5%;
      font-size: 1.1rem;
      animation-delay: 4s;
    }

    .equation-overlay.eq4 {
      bottom: 10%;
      left: 30%;
      font-size: 1.6rem;
      animation-delay: 6s;
    }

    .equation-overlay.eq5 {
      top: 5%;
      right: 25%;
      font-size: 1rem;
      animation-delay: 8s;
    }

    @keyframes floatEquation {

      0%,
      100% {
        transform: translate(0, 0);
      }

      25% {
        transform: translate(5px, -5px);
      }

      50% {
        transform: translate(-5px, 5px);
      }

      75% {
        transform: translate(5px, 5px);
      }
    }

    .hero-info h1 {
      font-size: 4.2rem;
      margin-bottom: 1rem;
      color: var(--heading-color);
      line-height: 1.05;
      letter-spacing: -3px;
    }

    .hero-info h1 span {
      color: transparent;
      background-clip: text;
      -webkit-background-clip: text;
      background-image: linear-gradient(135deg, var(--primary-color), var(--accent-color));
    }

    body.dark-mode .hero-info h1 span {
      text-shadow: 0 0 30px rgba(100, 244, 172, 0.4);
      color: var(--primary-color);
      background-image: none;
    }

    .hero-info p.subtitle {
      font-size: 1.3rem;
      font-weight: 500;
      margin-bottom: 1.5rem;
      color: var(--primary-color);
      min-height: 2.8rem;
      display: flex;
      align-items: center;
    }

    .hero-info p.subtitle .cursor {
      display: inline-block;
      background-color: var(--primary-color);
      margin-left: 0.2rem;
      width: 4px;
      height: 1.4rem;
      animation: blink 1s infinite;
      box-shadow: 0 0 5px var(--primary-color);
    }

    @keyframes blink {
      50% {
        opacity: 0;
      }
    }

    .hero-info p.description {
      margin-bottom: 2.5rem;
      line-height: 1.8;
      max-width: 540px;
      font-size: 1.05rem;
    }

    /* Premium Buttons */
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
      padding: 0.9rem 2.2rem;
      border-radius: 50px;
      font-weight: 700;
      color: #fff;
      transition: var(--transition);
      letter-spacing: 1px;
      text-transform: uppercase;
      font-size: 0.9rem;
      border: none;
      cursor: pointer;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
      position: relative;
    }

    body.dark-mode .cta-btn {
      color: #000;
      box-shadow: 0 10px 25px rgba(100, 244, 172, 0.25);
    }

    .cta-btn:hover {
      transform: translateY(-4px);
      box-shadow: 0 15px 30px rgba(100, 244, 172, 0.4);
    }

    .cta-btn:active {
      transform: translateY(2px);
      box-shadow: 0 5px 10px rgba(100, 244, 172, 0.2);
    }

    .hero-image img {
      max-width: 90%;
      border-radius: 20px;
      box-shadow: var(--box-shadow);
      animation: float 6s ease-in-out infinite;
    }

    @keyframes float {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-15px);
      }
    }

    /* --- ABOUT --- */
    .init-message {
      background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
      color: #fff;
      padding: 2rem;
      margin: -4rem auto 2rem;
      max-width: 900px;
      border-radius: 12px;
      text-align: center;
      font-style: italic;
      position: relative;
      z-index: 10;
      box-shadow: var(--box-shadow);
      font-weight: 600;
      transform: perspective(500px) rotateX(2deg);
      backdrop-filter: blur(10px);
    }

    body.dark-mode .init-message {
      color: #000;
    }

    .about-content {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 4rem;
      align-items: start;
    }

    .about-info h3 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
      color: var(--heading-color);
    }

    .volunteer-badge {
      display: inline-block;
      background-color: rgba(100, 244, 172, 0.1);
      color: var(--heading-color);
      border-left: 4px solid var(--primary-color);
      padding: 1rem;
      margin-top: 1.5rem;
      border-radius: 0 8px 8px 0;
      font-size: 0.95rem;
      transition: transform 0.3s;
    }

    .volunteer-badge:hover {
      transform: translateX(10px);
      background-color: rgba(100, 244, 172, 0.15);
    }

    body.dark-mode .volunteer-badge {
      background-color: rgba(255, 255, 255, 0.05);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      margin-top: 0.5rem;
    }

    .stat-item {
      background-color: var(--card-bg-color);
      padding: 2rem;
      border-radius: 16px;
      box-shadow: var(--box-shadow);
      text-align: center;
      transition: var(--transition);
      border: var(--card-border);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transform-style: preserve-3d;
    }

    .stat-item .number {
      font-size: 3rem;
      font-weight: 700;
      color: var(--primary-color);
      margin-bottom: 0.5rem;
      line-height: 1;
      transform: translateZ(20px);
      text-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    /* --- PRINCIPLES --- */
    .principles {
      background-color: var(--card-bg-color);
    }

    .principles-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }

    .principle-item {
      padding: 2.5rem;
      background-color: var(--card-bg-color);
      border-radius: 16px;
      box-shadow: var(--box-shadow);
      border: var(--card-border);
      backdrop-filter: blur(12px);
      transition: var(--transition);
      position: relative;
      overflow: hidden;
      height: 100%;
      transform-style: preserve-3d;
    }

    .principle-item::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 4px;
      height: 100%;
      background-color: var(--primary-color);
      transition: var(--transition);
    }

    .principle-item:hover {
      transform: translateY(-10px);
    }

    .principle-item:hover::before {
      width: 100%;
      opacity: 0.1;
    }

    .principle-icon {
      font-size: 2.5rem;
      color: var(--primary-color);
      margin-bottom: 1.5rem;
      background: rgba(100, 244, 172, 0.1);
      width: 70px;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      transform: translateZ(30px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    /* --- SKILLS --- */
    .skills-content {
      max-width: 900px;
      margin: 0 auto;
    }

    .skill-category {
      margin-bottom: 4rem;
    }

    .skill-bars {
      display: grid;
      gap: 1.8rem;
    }

    .skill-bar {
      position: relative;
      overflow: hidden;
      padding: 0.8rem 1rem;
      background: var(--card-bg-color);
      border-radius: 12px;
      border: var(--card-border);
      backdrop-filter: blur(8px);
      transition: transform 0.3s;
      box-shadow: inset 2px 2px 5px rgba(0, 0, 0, 0.02), var(--box-shadow);
    }

    .skill-bar:hover {
      transform: scale(1.02);
    }

    .skill-bar .info {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.5rem;
      font-weight: 600;
      color: var(--heading-color);
      z-index: 2;
      position: relative;
    }

    .skill-bar .bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 6px;
      width: 100%;
      background-color: rgba(0, 0, 0, 0.05);
    }

    .skill-bar .progress {
      height: 100%;
      background-color: var(--primary-color);
      width: 0;
      transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);
      box-shadow: 0 0 10px var(--primary-color);
    }

    /* --- HOBBIES --- */
    .hobbies {
      background-color: var(--bg-color);
    }

    .hobbies-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }

    .hobby-card {
      background: var(--card-bg-color);
      border-radius: 16px;
      padding: 2rem;
      text-align: center;
      box-shadow: var(--box-shadow);
      border: var(--card-border);
      backdrop-filter: blur(12px);
      transition: var(--transition);
      transform-style: preserve-3d;
    }

    .hobby-card:hover {
      border-color: var(--primary-color);
      transform: translateY(-10px);
    }

    .hobby-icon {
      font-size: 2.5rem;
      color: var(--primary-color);
      margin-bottom: 1rem;
      transform: translateZ(25px);
    }

    .hobby-card h3 {
      margin-bottom: 0.5rem;
      color: var(--heading-color);
      transform: translateZ(15px);
    }

    .hobby-card p {
      font-size: 0.9rem;
      opacity: 0.8;
      transform: translateZ(10px);
    }

    /* --- FEATURED PROJECT --- */
    .featured-wrapper {
      margin-bottom: 5rem;
      perspective: 1500px;
    }

    .featured-project {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      background: var(--card-bg-color);
      border-radius: 24px;
      overflow: visible;
      box-shadow: var(--box-shadow);
      border: var(--card-border);
      position: relative;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      transform-style: preserve-3d;
      transition: var(--transition);
    }

    .featured-project:hover {
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
      transform: translateY(-5px);
    }

    .featured-content {
      padding: 3.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      z-index: 2;
      transform: translateZ(40px);
    }

    .featured-label {
      display: inline-block;
      background: rgba(100, 244, 172, 0.15);
      color: var(--primary-color);
      padding: 0.4rem 1rem;
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      width: fit-content;
      margin-bottom: 1.5rem;
      border: 1px solid rgba(100, 244, 172, 0.3);
      box-shadow: 0 0 15px rgba(100, 244, 172, 0.2);
    }

    .featured-content h3 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: var(--heading-color);
      line-height: 1.1;
    }

    .featured-content p {
      margin-bottom: 2rem;
      opacity: 0.9;
      font-size: 1.05rem;
      max-width: 90%;
    }

    .tech-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-bottom: 2.5rem;
    }

    .tech-stack li {
      font-family: 'Roboto Mono', monospace;
      font-size: 0.8rem;
      color: var(--text-color);
      background: var(--bg-color);
      padding: 0.4rem 0.8rem;
      border-radius: 6px;
      border: 1px solid rgba(0, 0, 0, 0.1);
      font-weight: 500;
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
    }

    body.dark-mode .tech-stack li {
      border-color: rgba(255, 255, 255, 0.1);
    }

    .featured-image {
      position: relative;
      overflow: hidden;
      min-height: 400px;
      border-radius: 0 24px 24px 0;
      transform: translateZ(20px);
    }

    .featured-image iframe {
      width: 100%;
      height: 100%;
      border: none;
      position: absolute;
      top: 0;
      left: 0;
    }

    .btn-outline {
      padding: 0.8rem 1.8rem;
      border: 2px solid var(--heading-color);
      color: var(--heading-color);
      border-radius: 50px;
      font-weight: 600;
      transition: var(--transition);
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: transparent;
      cursor: pointer;
    }

    .btn-outline:hover {
      background: var(--heading-color);
      color: var(--bg-color);
      transform: translateY(-3px);
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

    body.dark-mode .btn-outline {
      border-color: var(--primary-color);
      color: var(--primary-color);
    }

    body.dark-mode .btn-outline:hover {
      background: var(--primary-color);
      color: #000;
      box-shadow: 0 0 15px rgba(100, 244, 172, 0.4);
    }

    /* --- PORTFOLIO GRID --- */
    .portfolio-filter {
      margin-bottom: 3.5rem;
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .filter-btn {
      background: transparent;
      color: var(--text-color);
      border: none;
      padding: 0.5rem 1.5rem;
      cursor: pointer;
      transition: var(--transition);
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      position: relative;
      font-size: 1rem;
    }

    .filter-btn.active,
    .filter-btn:hover {
      color: var(--primary-color);
      text-shadow: 0 0 10px var(--primary-color);
    }

    .filter-btn::after {
      content: '';
      position: absolute;
      width: 0%;
      height: 2px;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      background-color: var(--primary-color);
      transition: width 0.3s;
      box-shadow: 0 0 5px var(--primary-color);
    }

    .filter-btn.active::after,
    .filter-btn:hover::after {
      width: 80%;
    }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 2.5rem;
      perspective: 1000px;
    }

    .portfolio-item {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      background: var(--card-bg-color);
      border: var(--card-border);
      box-shadow: var(--box-shadow);
      backdrop-filter: blur(10px);
      transition: var(--transition);
      transform-style: preserve-3d;
    }

    .portfolio-item img {
      width: 100%;
      height: 260px;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .portfolio-info {
      padding: 1.5rem;
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.95) 10%, rgba(0, 0, 0, 0.7) 60%, transparent);
      transform: translateY(50%) translateZ(20px);
      transition: transform 0.4s ease;
    }

    .portfolio-item:hover .portfolio-info {
      transform: translateY(0) translateZ(30px);
    }

    .portfolio-info h3 {
      color: #fff;
      font-size: 1.3rem;
      margin-bottom: 0.3rem;
      text-shadow: 0 2px 5px rgba(0, 0, 0, 0.5);
    }

    .portfolio-info p {
      color: #ddd;
      font-size: 0.9rem;
      margin-bottom: 1rem;
      opacity: 0;
      transition: opacity 0.4s ease 0.1s;
    }

    .portfolio-item:hover .portfolio-info p {
      opacity: 1;
    }

    .portfolio-links-mini {
      display: flex;
      gap: 0.8rem;
    }

    .portfolio-links-mini a {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(5px);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      transition: var(--transition);
    }

    .portfolio-links-mini a:hover {
      background: var(--primary-color);
      color: #000;
      transform: scale(1.1);
    }

    /* --- CONTACT --- */
    .contact {
      background-color: var(--card-bg-color);
      position: relative;
      overflow: hidden;
    }

    .cube-container {
      position: absolute;
      bottom: 50px;
      right: 5%;
      width: 100px;
      height: 100px;
      perspective: 800px;
      z-index: 0;
      opacity: 0.4;
      pointer-events: none;
    }

    .cube {
      width: 100%;
      height: 100%;
      position: relative;
      transform-style: preserve-3d;
      animation: rotateCube 10s infinite linear;
    }

    .cube-face {
      position: absolute;
      width: 100px;
      height: 100px;
      border: 2px solid var(--primary-color);
      background: rgba(100, 244, 172, 0.1);
      box-shadow: 0 0 15px rgba(100, 244, 172, 0.2);
    }

    .cube-face:nth-child(1) {
      transform: rotateY(0deg) translateZ(50px);
    }

    .cube-face:nth-child(2) {
      transform: rotateY(90deg) translateZ(50px);
    }

    .cube-face:nth-child(3) {
      transform: rotateY(180deg) translateZ(50px);
    }

    .cube-face:nth-child(4) {
      transform: rotateY(-90deg) translateZ(50px);
    }

    .cube-face:nth-child(5) {
      transform: rotateX(90deg) translateZ(50px);
    }

    .cube-face:nth-child(6) {
      transform: rotateX(-90deg) translateZ(50px);
    }

    @keyframes rotateCube {
      0% {
        transform: rotateX(0deg) rotateY(0deg);
      }

      100% {
        transform: rotateX(360deg) rotateY(360deg);
      }
    }

    .contact-content {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 4rem;
      align-items: start;
      position: relative;
      z-index: 1;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      margin-bottom: 1.5rem;
      padding: 1.2rem;
      background: var(--card-bg-color);
      border: var(--card-border);
      backdrop-filter: blur(12px);
      border-radius: 12px;
      box-shadow: var(--box-shadow);
      transition: var(--transition);
      transform-style: preserve-3d;
    }

    .contact-item:hover {
      transform: translateX(10px) translateZ(10px);
    }

    .contact-item .icon {
      width: 45px;
      height: 45px;
      border-radius: 50%;
      background-color: var(--primary-color);
      display: flex;
      justify-content: center;
      align-items: center;
      color: #000;
      font-size: 1.2rem;
      flex-shrink: 0;
      box-shadow: 0 0 10px var(--primary-color);
    }

    body:not(.dark-mode) .contact-item .icon {
      color: #fff;
    }

    .social-links {
      display: flex;
      gap: 1rem;
      margin-top: 2.5rem;
    }

    .social-links a {
      width: 50px;
      height: 50px;
      border-radius: 12px;
      background-color: var(--bg-color);
      box-shadow: var(--box-shadow);
      display: flex;
      justify-content: center;
      align-items: center;
      color: var(--text-color);
      font-size: 1.4rem;
      transition: var(--transition);
      border: 1px solid transparent;
    }

    .social-links a:hover {
      background-color: var(--primary-color);
      color: #000;
      transform: translateY(-5px) rotate(5deg) scale(1.1);
      border-color: var(--primary-color);
      box-shadow: 0 0 15px var(--primary-color);
    }

    .contact-form {
      background-color: var(--card-bg-color);
      border: var(--card-border);
      backdrop-filter: blur(16px);
      padding: 3rem;
      border-radius: 20px;
      box-shadow: var(--box-shadow);
      transform-style: preserve-3d;
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--heading-color);
      font-weight: 600;
      font-size: 0.9rem;
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 1rem;
      border: 2px solid rgba(0, 0, 0, 0.1);
      border-radius: 8px;
      background-color: var(--card-bg-color);
      color: var(--text-color);
      transition: all 0.3s ease;
      font-family: 'Inter', sans-serif;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--primary-color);
      background-color: var(--bg-color);
      box-shadow: 0 0 0 4px rgba(100, 244, 172, 0.1);
      transform: translateZ(5px);
    }

    .form-submit-btn {
      width: 100%;
      background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
      border: none;
      padding: 1.2rem;
      border-radius: 50px;
      font-size: 1.1rem;
      font-weight: 700;
      cursor: pointer;
      transition: var(--transition);
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #fff;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
      position: relative;
    }

    body.dark-mode .form-submit-btn {
      color: #000;
      box-shadow: 0 10px 25px rgba(100, 244, 172, 0.25);
    }

    .form-submit-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 30px rgba(100, 244, 172, 0.4);
    }

    .form-submit-btn:active {
      transform: translateY(2px);
      box-shadow: 0 5px 10px rgba(0, 0, 0, 0.2);
    }

    footer {
      background-color: #111;
      color: #888;
      text-align: center;
      padding: 3rem 0;
      font-size: 0.9rem;
      border-top: 1px solid #222;
    }

    .animate-on-scroll {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .animate-on-scroll.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    #back-to-top {
      position: fixed;
      bottom: 30px;
      right: 30px;
      background-color: var(--primary-color);
      color: #000;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      z-index: 999;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s;
      transform: translateY(20px);
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    }

    #back-to-top:hover {
      transform: translateY(-5px);
      box-shadow: 0 0 20px var(--primary-color);
    }

    #back-to-top.visible {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    @media (max-width: 992px) {

      .hero-content,
      .about-content,
      .contact-content {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 3rem;
      }

      .hero-info h1 {
        font-size: 2.8rem;
      }

      .hero-info p.description {
        margin: 0 auto 2rem;
      }

      .hero-info p.subtitle {
        justify-content: center;
      }

      .hero-image {
        order: -1;
        margin-bottom: 1rem;
      }

      .featured-project {
        grid-template-columns: 1fr;
      }

      .featured-image {
        order: -1;
        min-height: 250px;
        border-radius: 24px 24px 0 0;
      }

      .featured-content {
        padding: 2rem;
      }

      .featured-project::after {
        background: linear-gradient(to top, var(--primary-color), transparent);
        opacity: 0.1;
      }

      .equation-overlay {
        display: none;
      }

      .about-content {
        gap: 2rem;
      }

      .volunteer-badge {
        margin-top: 1rem;
        border-left: none;
        border-top: 4px solid var(--primary-color);
        border-radius: 8px;
      }

      .cube-container {
        display: none;
      }
    }

    /* --- MOBILE NAV & LANG FIX --- */
    @media (max-width: 768px) {
      nav ul {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background-color: rgba(255, 255, 255, 0.98);
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 2.5rem;
        transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1);
        transform: translateY(-100%);
        opacity: 0;
        z-index: 1001;
        box-shadow: none;
        padding: 0;
      }

      body.dark-mode nav ul {
        background-color: rgba(18, 18, 18, 0.98);
      }

      nav ul.active {
        transform: translateY(0);
        opacity: 1;
      }

      nav ul li a {
        font-size: 2rem;
        font-weight: 700;
        color: var(--heading-color);
      }

      nav ul li a:hover {
        color: var(--primary-color);
      }

      .mobile-nav-toggle {
        display: block;
        position: relative;
        z-index: 1002;
        width: 30px;
        height: 30px;
        text-align: center;
        line-height: 30px;
      }

      .section-title {
        font-size: 2rem;
      }

      /* Hide Header Lang on Mobile */
      .utility-controls .lang-selector {
        display: none;
      }

      /* Show Mobile Internal Lang */
      .mobile-only-lang {
        display: flex !important;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
        margin-top: 2rem;
      }

      .mobile-only-lang .lang-btn {
        font-size: 1.2rem;
        padding: 0.5rem 1rem;
        border: 1px solid rgba(0, 0, 0, 0.1);
      }

      .mobile-only-lang .lang-btn.active {
        background-color: var(--primary-color);
        color: #000;
        font-weight: bold;
      }
    }

    /* --- SPLASH SCREEN (INTEGRATED SCI-FI) --- */
    body.no-scroll {
      overflow: hidden;
      height: 100vh;
    }

    #splash-screen {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(5, 5, 5, 0.75);
      backdrop-filter: blur(15px);
      -webkit-backdrop-filter: blur(15px);
      z-index: 10000;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      transition: opacity 0.6s ease, transform 0.6s ease;
      font-family: 'Roboto Mono', monospace;
    }

    #splash-screen.hidden {
      opacity: 0;
      pointer-events: none;
      transform: scale(1.05);
    }

    .splash-content {
      width: 90%;
      max-width: 800px;
      text-align: center;
      z-index: 2;
      padding: 3rem;
      background: var(--card-bg-color);
      border: var(--card-border);
      border-radius: 12px;
      box-shadow: var(--glass-shadow);
    }

    .term-header {
      color: var(--primary-color);
      font-size: 1.1rem;
      margin-bottom: 1.5rem;
      opacity: 0.9;
      line-height: 1.5;
      font-family: 'Inter', sans-serif;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .splash-title {
      font-size: 2rem;
      color: var(--heading-color);
      margin-bottom: 2.5rem;
      font-weight: 700;
      letter-spacing: -1px;
      text-transform: uppercase;
      font-family: 'Inter', sans-serif;
    }

    .splash-langs {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      opacity: 0;
      animation: fadeIn 0.4s forwards 0.2s;
    }

    .splash-btn {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid var(--primary-color);
      color: var(--heading-color);
      padding: 1rem 1.5rem;
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 1.1rem;
      text-align: center;
      cursor: pointer;
      transition: all 0.3s ease;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .splash-btn:hover {
      background: var(--primary-color);
      color: #000;
      box-shadow: 0 0 15px var(--primary-color);
      transform: translateY(-3px);
    }

    @keyframes fadeIn {
      to {
        opacity: 1;
      }
    }

    @keyframes blink-cursor {
      50% {
        border-color: transparent
      }
    }

    /* --- FLOATING ROBOT --- */
    .floating-robot {
      position: fixed;
      bottom: 30px;
      right: 30px;
      z-index: 9999;
      cursor: pointer;
      animation: floatBot 3s ease-in-out infinite;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .robot-antenna {
      width: 4px;
      height: 15px;
      background: var(--primary-color);
      border-radius: 2px;
      position: relative;
    }

    .robot-antenna::after {
      content: '';
      position: absolute;
      top: -5px;
      left: -3px;
      width: 10px;
      height: 10px;
      background: var(--primary-color);
      border-radius: 50%;
      box-shadow: 0 0 10px var(--primary-color);
      animation: blink 2s infinite;
    }

    .robot-head {
      width: 50px;
      height: 40px;
      background: var(--card-bg-color);
      border: var(--card-border);
      border-radius: 10px;
      position: relative;
      display: flex;
      justify-content: space-evenly;
      align-items: center;
      padding: 0 10px;
      box-shadow: var(--box-shadow);
      backdrop-filter: blur(5px);
    }

    .robot-eye {
      width: 10px;
      height: 10px;
      background: var(--primary-color);
      border-radius: 50%;
      box-shadow: 0 0 8px var(--primary-color);
      animation: robotBlink 4s infinite;
    }

    .robot-mouth {
      position: absolute;
      bottom: 8px;
      left: 50%;
      transform: translateX(-50%);
      width: 15px;
      height: 3px;
      background: var(--primary-color);
      border-radius: 2px;
      opacity: 0.8;
    }

    .robot-speech-bubble {
      position: absolute;
      bottom: 70px;
      right: 0;
      background: var(--card-bg-color);
      border: var(--card-border);
      padding: 10px 15px;
      border-radius: 15px;
      border-bottom-right-radius: 0;
      color: var(--heading-color);
      font-size: 0.9rem;
      font-family: 'Inter', sans-serif;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transition: var(--transition);
      transform: translateY(10px);
      box-shadow: var(--glass-shadow);
      backdrop-filter: blur(10px);
    }

    .floating-robot:hover .robot-speech-bubble {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes floatBot {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-15px);
      }
    }

    @keyframes robotBlink {

      0%,
      48%,
      52%,
      100% {
        transform: scaleY(1);
      }

      50% {
        transform: scaleY(0.1);
      }
    }

    /* --- EXPERIENCE TIMELINE --- */
    .experience {
      background-color: var(--bg-color);
    }

    .timeline {
      position: relative;
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 0;
      font-family: 'Roboto Mono', monospace;
    }

    .timeline::after {
      content: '';
      position: absolute;
      width: 2px;
      background: var(--card-border);
      top: 0;
      bottom: 0;
      left: 50%;
      margin-left: -1px;
    }

    .timeline-container {
      padding: 10px 40px;
      position: relative;
      background-color: inherit;
      width: 50%;
    }

    .timeline-container::after {
      content: '';
      position: absolute;
      width: 14px;
      height: 14px;
      right: -7px;
      background-color: var(--bg-color);
      border: 2px solid var(--primary-color);
      top: 20px;
      border-radius: 50%;
      z-index: 1;
      box-shadow: 0 0 10px var(--primary-color);
    }

    .timeline-left {
      left: 0;
    }

    .timeline-right {
      left: 50%;
    }

    .timeline-left::before {
      content: " ";
      height: 0;
      position: absolute;
      top: 22px;
      width: 0;
      z-index: 1;
      right: 30px;
      border: medium solid var(--card-border);
      border-width: 10px 0 10px 10px;
      border-color: transparent transparent transparent var(--card-border);
    }

    .timeline-right::before {
      content: " ";
      height: 0;
      position: absolute;
      top: 22px;
      width: 0;
      z-index: 1;
      left: 30px;
      border: medium solid var(--card-border);
      border-width: 10px 10px 10px 0;
      border-color: transparent var(--card-border) transparent transparent;
    }

    .timeline-right::after {
      left: -7px;
    }

    .timeline-content {
      padding: 20px 30px;
      background: var(--card-bg-color);
      position: relative;
      border-radius: 4px;
      border: var(--card-border);
      backdrop-filter: blur(5px);
      transition: var(--transition);
    }

    .timeline-content:hover {
      transform: translateY(-5px);
      box-shadow: var(--glass-shadow);
      border-color: var(--primary-color);
    }

    .timeline-content h3 {
      color: var(--heading-color);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
    }

    .timeline-content h3 i {
      color: var(--primary-color);
    }

    .timeline-date {
      color: var(--primary-color);
      font-size: 0.85rem;
      margin-bottom: 1rem;
      display: block;
      opacity: 0.9;
    }

    @media screen and (max-width: 768px) {
      .timeline::after {
        left: 31px;
      }

      .timeline-container {
        width: 100%;
        padding-left: 70px;
        padding-right: 25px;
        left: 0 !important;
      }

      .timeline-container::before {
        left: 60px;
        border: medium solid var(--card-border);
        border-width: 10px 10px 10px 0;
        border-color: transparent var(--card-border) transparent transparent;
      }

      .timeline-left::after,
      .timeline-right::after {
        left: 24px;
      }
    }
  </style>
</head>

