    let vantaEffect;

    /* --- 1. AUDIO SYSTEM --- */
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    let isMuted = false;

    function playSound(type) {
      if (isMuted || audioCtx.state === 'suspended') {
        if (audioCtx.state === 'suspended') audioCtx.resume();
        if (isMuted) return;
      }

      const now = audioCtx.currentTime;
      const masterGain = audioCtx.createGain();
      masterGain.connect(audioCtx.destination);
      masterGain.gain.setValueAtTime(0.05, now);

      if (type === 'hover') {
        for (let i = 0; i < 3; i++) {
          const osc = audioCtx.createOscillator();
          osc.type = 'square';
          const freq = 800 + Math.random() * 600;
          osc.frequency.setValueAtTime(freq, now + (i * 0.04));
          osc.connect(masterGain);
          osc.start(now + (i * 0.04));
          osc.stop(now + (i * 0.04) + 0.03);
        }
      } else if (type === 'click') {
        const osc = audioCtx.createOscillator();
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(300, now);
        osc.frequency.exponentialRampToValueAtTime(50, now + 0.15);
        osc.connect(masterGain);
        osc.start(now);
        osc.stop(now + 0.15);
      }
    }

    const soundBtn = document.getElementById('sound-btn');
    soundBtn.addEventListener('click', () => {
      isMuted = !isMuted;
      soundBtn.classList.toggle('muted');
      soundBtn.querySelector('i').className = isMuted ? 'fas fa-volume-mute' : 'fas fa-volume-up';
      if (!isMuted && audioCtx.state === 'suspended') audioCtx.resume();
    });

    /* --- 2. HACKER TEXT EFFECT --- */
    function hackerEffect(element) {
      const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789*&%$#@!";
      let interval = null;
      let iteration = 0;
      const originalText = element.dataset.originalText || element.innerText;
      if (!element.dataset.originalText) { element.dataset.originalText = element.innerText; }
      clearInterval(interval);
      interval = setInterval(() => {
        element.innerText = originalText.split("").map((letter, index) => {
          if (index < iteration) return originalText[index];
          if (originalText[index] === ' ') return ' ';
          return letters[Math.floor(Math.random() * letters.length)];
        }).join("");
        if (iteration >= originalText.length) {
          clearInterval(interval);
          if (element.dataset.originalKey && translations[currentLang][element.dataset.originalKey]) {
            element.innerHTML = translations[currentLang][element.dataset.originalKey];
          } else { element.innerText = originalText; }
        }
        iteration += originalText.length / 30;
      }, 30);
    }

    /* --- 3. VANTA BG --- */
    function initVanta(isDarkMode) {
      if (vantaEffect) vantaEffect.destroy();
      const options = {
        el: "#home", mouseControls: true, touchControls: true, gyroControls: false,
        minHeight: 200.00, minWidth: 200.00, scale: 1.00, scaleMobile: 1.00, speed: 1.2
      };
      if (isDarkMode) {
        options.color = 0x64f4ac; options.backgroundColor = 0x0b0d10; options.size = 0.8;
      } else {
        options.color = 0x3b3c40; options.backgroundColor = 0xf0f0f2; options.size = 1.1;
      }
      vantaEffect = VANTA.GLOBE(options);
    }

    /* --- 4. CURSOR CONSTELLATION CANVAS --- */
    const canvas = document.getElementById('cursor-canvas');
    const ctx = canvas.getContext('2d');
    let width, height, particles = [];

    function resizeCanvas() { width = window.innerWidth; height = window.innerHeight; canvas.width = width; canvas.height = height; }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    const mouse = { x: -100, y: -100 };
    window.addEventListener('mousemove', (e) => {
      mouse.x = e.clientX; mouse.y = e.clientY;
      particles.push({ x: mouse.x, y: mouse.y, life: 1, vx: (Math.random() - 0.5), vy: (Math.random() - 0.5) });
    });

    function animateCursor() {
      ctx.clearRect(0, 0, width, height);
      // Avoid querying DOM on every frame
      const isDark = document.body.classList.contains('dark-mode');
      const color = isDark ? '100, 244, 172' : '59, 60, 64';

      for (let i = 0; i < particles.length; i++) {
        let p = particles[i]; p.life -= 0.03; p.x += p.vx; p.y += p.vy;
        if (p.life <= 0) { particles.splice(i, 1); i--; continue; }

        ctx.beginPath(); ctx.arc(p.x, p.y, 1.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${color}, ${p.life})`; ctx.fill();

        for (let j = i + 1; j < particles.length; j++) {
          let p2 = particles[j];
          let dist = Math.hypot(p.x - p2.x, p.y - p2.y);
          if (dist < 60) {
            ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = `rgba(${color}, ${p.life * 0.5})`; ctx.lineWidth = 0.5; ctx.stroke();
          }
        }
      }
      requestAnimationFrame(animateCursor);
    }
    animateCursor();

    /* --- 5. MAGNETIC EQUATIONS --- */
    const equations = document.querySelectorAll('.equation-overlay');
    document.addEventListener('mousemove', (e) => {
